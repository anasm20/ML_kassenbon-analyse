# ---------------------------------------------------------------------------
# Vorlage fuer die Zugangsdaten.
# Kopiere diese Datei zu  .env  und trage deine echten Werte ein.
# Die .env-Datei NICHT ins Repository / in die Abgabe-ZIP mit echten Keys legen!
# ---------------------------------------------------------------------------

# Azure AI Document Intelligence
AZURE_DI_ENDPOINT=https://NAME.azure.com/
AZURE_DI_KEY=DEIN_DOCUMENT_INTELLIGENCE_KEY

# Mistral Document AI / OCR (Azure AI Foundry)
AZURE_MISTRAL_ENDPOINT=https://NAME.services.ai.azure.com/providers/mistral/azure/ocr
AZURE_MISTRAL_KEY=DEIN_MISTRAL_KEY
AZURE_MISTRAL_MODEL=mistral-document-ai-2512

# Optional: nur ausfuellen, falls dein Foundry-Endpoint eine api-version verlangt
AZURE_MISTRAL_API_VERSION=
